---
import Email from "../../icons/Email.astro";
import Github from "../../icons/Github.astro";
import Linkedin from "../../icons/Linkedin.astro";
import Whatsapp from "../../icons/Whatsapp.astro";
import { media_links } from "../../assets/info";
---

<footer class="flex items-center justify-between py-10">
    <small>
        <a href="/">Lucas Rodríguez</a>
    </small>
    <ul class="flex flex-row gap-6">
        <li>
            <a href={media_links.linkedin} target="_blank">
                <Linkedin class="w-4 h-4" />
            </a>
        </li>
        <li>
            <a href={media_links.github} target="_blank">
                <Github class="w-4 h-4" />
            </a>
        </li>
        <li>
            <a href={media_links.email}>
                <Email class="w-4 h-4" />
            </a>
        </li>
        <li>
            <a href={media_links.whatsapp} target="_blank" rel="noopener noreferrer">
                <Whatsapp class="w-4 h-4" />
            </a>
        </li>
    </ul>
</footer>
